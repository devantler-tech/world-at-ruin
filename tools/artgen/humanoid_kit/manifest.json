    { "name": "arms_heavy", "targets": ["arms/l-upperarm-fat-incr.target.gz", "arms/r-upperarm-fat-incr.target.gz", "arms/l-lowerarm-fat-incr.target.gz", "arms/r-lowerarm-fat-incr.target.gz"] },
